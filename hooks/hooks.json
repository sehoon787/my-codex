{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/hooks/session-start.sh\"",
            "timeout": 15000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs');const d='.briefing/agents';if(fs.existsSync('.briefing/INDEX.md')){fs.mkdirSync(d,{recursive:true});const j=JSON.parse(fs.readFileSync(0,'utf8'));const tool=j.tool_name||'unknown';if(tool==='Agent'){const e={ts:new Date().toISOString(),tool:tool,agent:j.tool_input?.name||'unknown'};fs.appendFileSync(d+'/agent-log.jsonl',JSON.stringify(e)+'\\n')}}\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.codex/hooks/stop-profile-update.js\"",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
